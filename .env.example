# AuraPeak Woodcraft Ltd - Environment Configuration

# Resend API Key for sending emails (obtain from resend.com)
VITE_RESEND_API_KEY=re_your_resend_api_key_here

# Configurable receiver email where inquiries will be delivered
VITE_CONTACT_RECEIVER_EMAIL=info@aurapeakwoodcraft.com

# Display email shown in footer and contact card
VITE_CONTACT_DISPLAY_EMAIL=info@aurapeakwoodcraft.com
